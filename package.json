{
  "name": "claude-conductor-tests",
  "private": true,
  "version": "0.1.119",
  "type": "module",
  "scripts": {
    "predev": "node scripts/kill-stale.mjs",
    "dev": "vite",
    "prebuild": "cargo test --manifest-path src-tauri/Cargo.toml --test export_types",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wdio run e2e/wdio.conf.js",
    "test:e2e:chat": "wdio run e2e/wdio.conf.js --spec e2e/specs/reload-dup.e2e.js",
    "test:e2e:changes": "wdio run e2e/wdio.conf.js --spec e2e/specs/changes-panel.e2e.js",
    "test:e2e:flow": "wdio run e2e/wdio.conf.js --spec e2e/specs/chat-flow.e2e.js",
    "test:e2e:news": "wdio run e2e/wdio.conf.js --spec e2e/specs/news-redesign.e2e.js",
    "kill-orphans": "node scripts/kill-dev-orphans.mjs"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "20.19.39",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "jsdom": "^29.0.2",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "diff": "^8.0.4",
    "lit-html": "3.3.2",
    "markdown-it": "^14.1.1",
    "qr-scanner": "1.4.2",
    "shiki": "^4.0.2"
  }
}
