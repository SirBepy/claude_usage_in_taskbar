{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage",
  "version": "0.1.55",
  "identifier": "com.aiusage.taskbar.tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage",
        "url": "index.html",
        "width": 520,
        "height": 720,
        "minWidth": 360,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; style-src-elem 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://unpkg.com; script-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: blob:; media-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "icon": ["icons/icon.png"],
    "publisher": "SirBepy",
    "category": "Utility",
    "shortDescription": "Claude AI usage in your taskbar",
    "longDescription": "Tray app that monitors Claude AI usage and shows it as progress rings in the system tray.",
    "resources": ["assets/sounds/*", "assets/characters/**/*"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SirBepy/claude_usage_in_taskbar/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyREUzNzgyMDU2QjhFN0EKUldSNmptc0ZnamZlY29kWDlDbE5xU0toUGhNN2dXemxjU3VZVmdMZHpxeUdDTXNoVUFNL2FmdFIK",
      "dialog": true
    }
  }
}
